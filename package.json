{
  "name": "money-track",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:android",
    "build:android": "npm run prebuild:android && ./android/gradlew -p android assembleRelease && mkdir -p build && mv android/app/build/outputs/apk/release/app-release.apk build/money-track.apk && rm -rf android",
    "prebuild:android": "npx expo prebuild --platform android --clean",
    "build:bundle": "npx expo export --output-dir build/bundle --platform ios",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zod": "^4.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
