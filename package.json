{
  "name": "money-track",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:android",
    "build:android": "npx eas build --platform android --profile local --local --output build/money-track.apk",
    "build:ios": "npx eas build --platform ios --profile local --local --output build/money-track.tar.gz",
    "build:bundle": "npx expo export --output-dir build/bundle --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "babel-preset-expo": "^55.0.18",
    "expo": "~54.0.33",
    "expo-camera": "^55.0.16",
    "expo-constants": "^55.0.15",
    "expo-crypto": "^55.0.14",
    "expo-document-picker": "^55.0.13",
    "expo-file-system": "^55.0.17",
    "expo-image-picker": "^55.0.19",
    "expo-linking": "^55.0.14",
    "expo-network": "^55.0.13",
    "expo-router": "^55.0.13",
    "expo-sharing": "^55.0.18",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~3.0.9",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "zod": "^4.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
